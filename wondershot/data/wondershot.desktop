[Desktop Entry]
Type=Application
Name=Wondershot
GenericName=Screenshot Tool
Comment=Capture, gallery with drag-out, markup editor
Exec=wondershot
Icon=wondershot
Terminal=false
Categories=Utility;Graphics;Photography;
StartupNotify=false
X-KDE-DBUS-Restricted-Interfaces=org.kde.KWin.ScreenShot2
Actions=capture;fullscreen;

[Desktop Action capture]
Name=Capture region
Exec=wondershot --capture
Icon=wondershot

[Desktop Action fullscreen]
Name=Capture full screen
Exec=wondershot --fullscreen
Icon=wondershot
